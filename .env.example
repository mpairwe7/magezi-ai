# =============================================================================
# Magezi — A-Level STEM Tutor Configuration
# =============================================================================
# cp .env.example .env — app works without any API key (uses local fallback)

# -- Application --------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=info

# -- LLM Backend (choose one) ------------------------------------------------
# Groq (free tier — recommended for hackathon)
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Claude (optional — requires Anthropic API key)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# CLAUDE_MODEL=claude-sonnet-4-6-20250514
# CLAUDE_THINKING_BUDGET=10000
# CLAUDE_PROMPT_CACHING=true

# Shared LLM settings
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.3

# -- Auth & Credits -----------------------------------------------------------
JWT_SECRET=magezi-hackathon-secret-change-in-production
JWT_EXPIRY_HOURS=72
FREE_CREDITS_ON_SIGNUP=50

# -- Qdrant (optional — keyword fallback handles 4,457 passages fine) ---------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=magezi_curriculum
GROUNDING_THRESHOLD=0.3

# -- Security -----------------------------------------------------------------
ALLOWED_ORIGINS=*

# -- Rate Limiting ------------------------------------------------------------
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW=60

# -- Session ------------------------------------------------------------------
SESSION_TTL_SECONDS=86400

# -- Frontend -----------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8802
NEXT_PUBLIC_APP_NAME=Magezi
